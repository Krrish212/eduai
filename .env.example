# ─── EduAI Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values before starting the server.

# Server
PORT=3000
NODE_ENV=development

# MongoDB — replace with your connection string
# Local:   mongodb://localhost:27017/eduai
# Atlas:   mongodb+srv://USER:PASS@cluster.mongodb.net/eduai
MONGODB_URI=mongodb://localhost:27017/eduai

# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Domain (used in email links, CORS origin)
SITE_URL=http://localhost:3000

# KPI Thresholds (tweak without code changes)
RISK_SCORE_HIGH=75
RISK_SCORE_MEDIUM=55
ENGAGEMENT_THRESHOLD=65
MASTERY_LOW_THRESHOLD=50
